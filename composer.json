{
    "name": "univeros/framework",
    "description": "The Univeros Framework.",
    "keywords": ["framework", "univeros"],
    "license": "MIT",
    "homepage": "https://univeros.io",
    "support": {
        "issues": "https://github.com/univeros/framework/issues",
        "source": "https://github.com/univeros/framework"
    },
    "require": {
        "php": ">=8.3",
        "ext-json": "*",
        "cycle/annotated": "^4.2",
        "cycle/database": "^2.10",
        "cycle/migrations": "^4.2",
        "cycle/orm": "^2.7",
        "cycle/schema-builder": "^2.7",
        "laminas/laminas-diactoros": "^3.5",
        "league/flysystem": "^3.29",
        "neomerx/cors-psr7": "^3.0",
        "nesbot/carbon": "^3.8",
        "nikic/fast-route": "^1.3",
        "nikic/php-parser": "^5.0",
        "psr/cache": "^3.0",
        "psr/container": "^2.0",
        "psr/event-dispatcher": "^1.0",
        "psr/http-factory": "^1.1",
        "psr/http-message": "^1.1 || ^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "psr/log": "^3.0",
        "psr/simple-cache": "^3.0",
        "relay/relay": "^2.1",
        "spiral/tokenizer": "^3.13",
        "symfony/console": "^7.0",
        "symfony/messenger": "^7.0",
        "symfony/serializer": "^7.0",
        "symfony/uid": "^7.0",
        "symfony/yaml": "^7.0",
        "vlucas/phpdotenv": "^5.6",
        "willdurand/negotiation": "^3.1"
    },
    "bin": [
        "bin/altair"
    ],
    "require-dev": {
        "ext-intl": "*",
        "ext-memcached": "*",
        "ext-mongodb": "*",
        "ext-redis": "*",
        "ext-openssl": "*",
        "friendsofphp/php-cs-fixer": "^3.64",
        "lcobucci/jwt": "^5.3",
        "league/flysystem-aws-s3-v3": "^3.29",
        "league/flysystem-sftp-v3": "^3.29",
        "league/flysystem-ftp": "^3.29",
        "mongodb/mongodb": "^2.0",
        "pda/pheanstalk": "^5.0",
        "phpstan/phpstan": "^1.12",
        "phpunit/phpunit": "^11.4",
        "predis/predis": "^2.2",
        "queue-interop/queue-interop": "^0.8.2",
        "rector/rector": "^1.2",
        "roave/security-advisories": "dev-latest",
        "spatie/flysystem-dropbox": "^3.0",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "autoload": {
        "psr-4": {
            "Altair\\": "src/Altair"
        }
    },
    "replace": {
        "univeros/agent-spec": "self.version",
        "univeros/cache": "self.version",
        "univeros/cli": "self.version",
        "univeros/common": "self.version",
        "univeros/configuration": "self.version",
        "univeros/container": "self.version",
        "univeros/cookie": "self.version",
        "univeros/courier": "self.version",
        "univeros/doctor": "self.version",
        "univeros/events": "self.version",
        "univeros/filesystem": "self.version",
        "univeros/happen": "self.version",
        "univeros/http": "self.version",
        "univeros/introspection": "self.version",
        "univeros/messaging": "self.version",
        "univeros/middleware": "self.version",
        "univeros/persistence": "self.version",
        "univeros/queue": "self.version",
        "univeros/sanitation": "self.version",
        "univeros/scaffold": "self.version",
        "univeros/security": "self.version",
        "univeros/session": "self.version",
        "univeros/structure": "self.version",
        "univeros/test-reporter": "self.version",
        "univeros/validation": "self.version"
    },
    "autoload-dev": {
        "psr-4": {
            "Altair\\Tests\\": "tests"
        },
        "files": [
            "tests/Container/fixtures.php",
            "tests/Courier/fixtures.php",
            "tests/Sanitation/fixtures.php",
            "tests/Validation/fixtures.php"
        ]
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html build/coverage",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "stan": "phpstan analyse --memory-limit=1G",
        "rector": "rector process --dry-run",
        "rector:fix": "rector process",
        "qa": [
            "@cs",
            "@stan",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": false
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
