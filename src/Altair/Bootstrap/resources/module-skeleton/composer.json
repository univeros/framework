{
    "name": "vendor/module",
    "description": "A Univeros module.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": ">=8.3",
        "univeros/module": "^2.0",
        "univeros/http": "^2.0",
        "univeros/persistence": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.4"
    },
    "autoload": {
        "psr-4": {
            "VendorModule\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "VendorModule\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
