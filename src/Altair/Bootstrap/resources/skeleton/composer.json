{
    "name": "univeros/univeros",
    "description": "An Altair Framework API.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.3",
        "univeros/framework": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "serve": "php -S localhost:8080 -t public"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
