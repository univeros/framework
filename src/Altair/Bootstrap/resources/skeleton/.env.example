APP_ENV=dev
APP_DEBUG=true
APP_KEY=changeme

# Logging (PSR-3 via Monolog). LOG_FORMAT: json (default) or line.
LOG_CHANNEL=app
LOG_LEVEL=debug
LOG_PATH=php://stderr
LOG_FORMAT=line

# Database (used when an ORM is configured)
DB_DRIVER=sqlite
DB_DATABASE=database/app.sqlite

# Messenger transport (used when a queue is configured)
MESSENGER_TRANSPORT_DSN=sync://
