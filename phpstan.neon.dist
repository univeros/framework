includes:
    - phpstan-baseline.neon

parameters:
    level: 6
    phpVersion: 80300
    paths:
        - src
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
    tmpDir: .phpstan-cache

    ignoreErrors:
        # PHP-side stubs for optional ext-* extensions vary across environments
        - identifier: function.notFound
          paths:
              - src/Altair/Cache/Storage/MemcachedCacheItemStorage.php
              - src/Altair/Cache/Storage/RedisCacheItemStorage.php
